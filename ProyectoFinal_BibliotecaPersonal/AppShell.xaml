<?xml version="1.0" encoding="UTF-8" ?>
<Shell
    x:Class="ProyectoFinal_BibliotecaPersonal.AppShell"
    xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
    xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
    xmlns:local="clr-namespace:ProyectoFinal_BibliotecaPersonal"
    xmlns:views="clr-namespace:ProyectoFinal_BibliotecaPersonal.Views"
    Shell.FlyoutBehavior="Flyout"
    Shell.BackgroundColor="#1A237E"
    Shell.ForegroundColor="White"
    Shell.TitleColor="White">

    <FlyoutItem Title="Biblioteca">
        <ShellContent ContentTemplate="{DataTemplate views:LibraryPage}" />
    </FlyoutItem>

    <FlyoutItem Title="Buscar Libro">
        <ShellContent ContentTemplate="{DataTemplate views:SearchPage}" />
    </FlyoutItem>

    <FlyoutItem Title="Estadísticas">
        <ShellContent ContentTemplate="{DataTemplate views:StatisticsPage}" />
    </FlyoutItem>

</Shell>