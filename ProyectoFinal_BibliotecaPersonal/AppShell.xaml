<?xml version="1.0" encoding="UTF-8" ?>
<Shell
    x:Class="ProyectoFinal_BibliotecaPersonal.AppShell"
    xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
    xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
    xmlns:views="clr-namespace:ProyectoFinal_BibliotecaPersonal.Views"
    Shell.FlyoutBehavior="Flyout">

    <Shell.FlyoutHeader>
        <Grid BackgroundColor="#512BD4" HeightRequest="150">
            <Label Text="Mi Biblioteca" 
                   TextColor="White" 
                   FontAttributes="Bold" 
                   FontSize="24"
                   HorizontalOptions="Center" 
                   VerticalOptions="Center"/>
        </Grid>
    </Shell.FlyoutHeader>

    <FlyoutItem Title="Biblioteca">
        <ShellContent ContentTemplate="{DataTemplate views:LibraryPage}" />
    </FlyoutItem>

    <FlyoutItem Title="Buscar">
        <ShellContent ContentTemplate="{DataTemplate views:SearchPage}" />
    </FlyoutItem>

    <FlyoutItem Title="Estadísticas">
        <ShellContent ContentTemplate="{DataTemplate views:StatisticsPage}" />
    </FlyoutItem>

</Shell>